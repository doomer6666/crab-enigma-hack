openapi: 3.0.3
info:
  title: Jarvis AI API
  version: 1.0.0
  description: 'API для хакатона: обработка тикетов техподдержки с помощью AI'
paths:
  /api/knowledge/:
    get:
      operationId: knowledge_list
      parameters:
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      tags:
      - knowledge
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/KnowledgeBaseArticle'
          description: ''
    post:
      operationId: knowledge_create
      tags:
      - knowledge
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/KnowledgeBaseArticle'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/KnowledgeBaseArticle'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/KnowledgeBaseArticle'
        required: true
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/KnowledgeBaseArticle'
          description: ''
  /api/knowledge/{id}/:
    get:
      operationId: knowledge_retrieve
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this knowledge base article.
        required: true
      tags:
      - knowledge
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/KnowledgeBaseArticle'
          description: ''
    put:
      operationId: knowledge_update
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this knowledge base article.
        required: true
      tags:
      - knowledge
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/KnowledgeBaseArticle'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/KnowledgeBaseArticle'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/KnowledgeBaseArticle'
        required: true
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/KnowledgeBaseArticle'
          description: ''
    patch:
      operationId: knowledge_partial_update
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this knowledge base article.
        required: true
      tags:
      - knowledge
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedKnowledgeBaseArticle'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedKnowledgeBaseArticle'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedKnowledgeBaseArticle'
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/KnowledgeBaseArticle'
          description: ''
    delete:
      operationId: knowledge_destroy
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this knowledge base article.
        required: true
      tags:
      - knowledge
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '204':
          description: No response body
  /api/tickets/:
    get:
      operationId: tickets_list
      parameters:
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - in: query
        name: priority
        schema:
          type: string
          enum:
          - critical
          - high
          - low
          - medium
        description: |-
          * `low` - Низкий
          * `medium` - Средний
          * `high` - Высокий
          * `critical` - Критический
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      - name: size
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      - in: query
        name: status
        schema:
          type: string
          enum:
          - ai_processed
          - awaiting_reply
          - closed
          - in_progress
          - new
          - resolved
        description: |-
          * `new` - Новый
          * `ai_processed` - Обработан AI
          * `in_progress` - В работе
          * `awaiting_reply` - Ожидает ответа
          * `resolved` - Решён
          * `closed` - Закрыт
      tags:
      - tickets
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedTicketList'
          description: ''
    post:
      operationId: tickets_create
      tags:
      - tickets
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Ticket'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/Ticket'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/Ticket'
        required: true
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Ticket'
          description: ''
  /api/tickets/{id}/:
    get:
      operationId: tickets_retrieve
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this ticket.
        required: true
      tags:
      - tickets
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Ticket'
          description: ''
    put:
      operationId: tickets_update
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this ticket.
        required: true
      tags:
      - tickets
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Ticket'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/Ticket'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/Ticket'
        required: true
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Ticket'
          description: ''
    patch:
      operationId: tickets_partial_update
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this ticket.
        required: true
      tags:
      - tickets
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedTicket'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedTicket'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedTicket'
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Ticket'
          description: ''
    delete:
      operationId: tickets_destroy
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this ticket.
        required: true
      tags:
      - tickets
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '204':
          description: No response body
  /api/tickets/{id}/messages/:
    get:
      operationId: tickets_messages_retrieve
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this ticket.
        required: true
      tags:
      - tickets
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Ticket'
          description: ''
components:
  schemas:
    Category:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 100
        description:
          type: string
      required:
      - id
      - name
    KnowledgeBaseArticle:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        title:
          type: string
          maxLength: 255
        content:
          type: string
        tags:
          type: string
          description: Теги через запятую
          maxLength: 255
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - content
      - created_at
      - id
      - title
      - updated_at
    PaginatedTicketList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=4
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=2
        results:
          type: array
          items:
            $ref: '#/components/schemas/Ticket'
    PatchedKnowledgeBaseArticle:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        title:
          type: string
          maxLength: 255
        content:
          type: string
        tags:
          type: string
          description: Теги через запятую
          maxLength: 255
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
    PatchedTicket:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        subject:
          type: string
          maxLength: 255
        sender_email:
          type: string
          format: email
          maxLength: 254
        sender_name:
          type: string
          nullable: true
          maxLength: 255
        category:
          allOf:
          - $ref: '#/components/schemas/Category'
          readOnly: true
        category_id:
          type: integer
          writeOnly: true
          nullable: true
        priority:
          $ref: '#/components/schemas/PriorityEnum'
        sentiment:
          $ref: '#/components/schemas/SentimentEnum'
        confidence:
          type: number
          format: double
          nullable: true
        status:
          $ref: '#/components/schemas/StatusEnum'
        ai_draft:
          type: string
          nullable: true
        assigned_to:
          type: integer
          nullable: true
        received_at:
          type: string
          format: date-time
          nullable: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
    PriorityEnum:
      enum:
      - low
      - medium
      - high
      - critical
      type: string
      description: |-
        * `low` - Низкий
        * `medium` - Средний
        * `high` - Высокий
        * `critical` - Критический
    SentimentEnum:
      enum:
      - positive
      - neutral
      - negative
      type: string
      description: |-
        * `positive` - Позитивный
        * `neutral` - Нейтральный
        * `negative` - Негативный
    StatusEnum:
      enum:
      - new
      - ai_processed
      - in_progress
      - awaiting_reply
      - resolved
      - closed
      type: string
      description: |-
        * `new` - Новый
        * `ai_processed` - Обработан AI
        * `in_progress` - В работе
        * `awaiting_reply` - Ожидает ответа
        * `resolved` - Решён
        * `closed` - Закрыт
    Ticket:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        subject:
          type: string
          maxLength: 255
        sender_email:
          type: string
          format: email
          maxLength: 254
        sender_name:
          type: string
          nullable: true
          maxLength: 255
        category:
          allOf:
          - $ref: '#/components/schemas/Category'
          readOnly: true
        category_id:
          type: integer
          writeOnly: true
          nullable: true
        priority:
          $ref: '#/components/schemas/PriorityEnum'
        sentiment:
          $ref: '#/components/schemas/SentimentEnum'
        confidence:
          type: number
          format: double
          nullable: true
        status:
          $ref: '#/components/schemas/StatusEnum'
        ai_draft:
          type: string
          nullable: true
        assigned_to:
          type: integer
          nullable: true
        received_at:
          type: string
          format: date-time
          nullable: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - category
      - created_at
      - id
      - sender_email
      - subject
      - updated_at
  securitySchemes:
    basicAuth:
      type: http
      scheme: basic
    cookieAuth:
      type: apiKey
      in: cookie
      name: sessionid
